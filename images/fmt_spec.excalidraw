          "id": "TO8MB7X9OxhCnJOCOh_qh",
          "type": "arrow"
        }
      ],
      "updated": 1774710194154,
      "link": null,
      "locked": false,
      "text": "[0] -> \n[1] -> extra 4 u32s\n[2] -> Doesn't seem to introduce anything extra\n[3] -> Doesn't seem to introduce anything extra\n[4] -> extra num near end, seems to be power of 2,\n        Lots of 32's, 64's\n[5] -> extra num at end, non-power of 2\n[6] -> 0 lightly correlated w/ more data\n[7] -> 0 lightly correlated with more data",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "[0] -> \n[1] -> extra 4 u32s\n[2] -> Doesn't seem to introduce anything extra\n[3] -> Doesn't seem to introduce anything extra\n[4] -> extra num near end, seems to be power of 2,\n        Lots of 32's, 64's\n[5] -> extra num at end, non-power of 2\n[6] -> 0 lightly correlated w/ more data\n[7] -> 0 lightly correlated with more data",
      "autoResize": true,
      "lineHeight": 1.25
    },
